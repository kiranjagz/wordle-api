{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WordleApi.Host",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/WordleApi.Host/bin/Debug/net10.0/WordleApi.Host.dll",
      "args": [],
      "cwd": "${workspaceFolder}/WordleApi.Host",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5050"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      }
    },
    {
      "name": "wordle-ui",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/wordle-ui",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Local:\\s+(https?://\\S+)"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["WordleApi.Host", "wordle-ui"]
    }
  ]
}
